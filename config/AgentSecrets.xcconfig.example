// AgentSecrets.xcconfig.example
// AFK Mac Agent Configuration
//
// Copy this to AgentSecrets.xcconfig and fill in your values.
// Do NOT commit AgentSecrets.xcconfig to version control.

// Apple Developer Team ID (find in developer.apple.com → Membership)
DEVELOPMENT_TEAM = YOUR_TEAM_ID

// Bundle identifier prefix (must match iOS Secrets.xcconfig for same account)
AFK_BUNDLE_PREFIX = your.prefix

// Agent bundle identifier
PRODUCT_BUNDLE_IDENTIFIER = $(AFK_BUNDLE_PREFIX).AFK-Agent

// Code signing
CODE_SIGN_STYLE = Automatic
CODE_SIGN_ENTITLEMENTS = AFK-Agent/AFK-Agent.entitlements
ENABLE_HARDENED_RUNTIME = YES

// App icon
ASSETCATALOG_COMPILER_APPICON_NAME = AppIcon
ASSETCATALOG_COMPILER_INCLUDE_ALL_APPICON_ASSETS = YES

// Server URL (use $() to escape the double slash in URLs)
// For local development:
AFK_SERVER_URL = ws:/$()/localhost:9847

// For production with TLS:
// AFK_SERVER_URL = wss:/$()/your-server.example.com

// Info.plist generation
GENERATE_INFOPLIST_FILE = YES

// Menu bar agent — no Dock icon
INFOPLIST_KEY_LSUIElement = YES

// Inject into Info.plist so Swift can read via Bundle.main
INFOPLIST_KEY_AFKServerURL = $(AFK_SERVER_URL)
