// Secrets.xcconfig.example
// AFK iOS App Configuration
//
// Copy this to Secrets.xcconfig and fill in your values.
// Do NOT commit Secrets.xcconfig to version control.

// Apple Developer Team ID (find in developer.apple.com → Membership)
DEVELOPMENT_TEAM = YOUR_TEAM_ID

// Bundle identifier prefix (your reverse domain, e.g. com.yourcompany)
AFK_BUNDLE_PREFIX = com.example

// Physical device server URL (use $() to escape the double slash in URLs)
// Simulator always uses localhost:9847 (see AppConfig.swift)
INFOPLIST_KEY_AFKAPIBaseURL = http:/$()/YOUR_HOST:9847
INFOPLIST_KEY_AFKWSBaseURL = ws:/$()/YOUR_HOST:9847

// For production with TLS:
// INFOPLIST_KEY_AFKAPIBaseURL = https:/$()/your-server.example.com
// INFOPLIST_KEY_AFKWSBaseURL = wss:/$()/your-server.example.com
