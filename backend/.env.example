# AFK Cloud Server Configuration

# Server
AFK_PORT=9847
AFK_DATABASE_URL=postgres://afk:afk@localhost:5432/afk?sslmode=disable

# REQUIRED — Generate with: openssl rand -hex 32
AFK_JWT_SECRET=

AFK_APPLE_BUNDLE_ID=com.afk.app

# Log level: debug, info, warn, error
AFK_LOG_LEVEL=info

# Ed25519 server key pair (hex-encoded, leave empty to auto-generate ephemeral key)
AFK_SERVER_PRIVATE_KEY=
AFK_SERVER_PUBLIC_KEY=

# Admin panel secret (min 32 chars when set). Generate with: openssl rand -hex 32
AFK_ADMIN_SECRET=

# Trusted proxy IPs (comma-separated). Only trust X-Real-IP from these addresses.
# Leave empty to trust all sources (backward compatible).
AFK_TRUSTED_PROXIES=

# APNs Push Notifications (leave empty to disable — server logs pushes instead)
AFK_APNS_KEY_PATH=
AFK_APNS_KEY_ID=
AFK_APNS_TEAM_ID=
AFK_APNS_BUNDLE_ID=
# Set to "1" for App Store / TestFlight builds. Leave empty for Xcode debug builds.
AFK_APNS_PRODUCTION=
